# Copiez ce fichier en ".env" et définissez la clé.
# Préfixe: GEO_ (pydantic-settings)

GEO_GROQ_API_KEY=
GEO_GROQ_MODEL=llama-3.3-70b-versatile
GEO_GROQ_MAX_CONCURRENT=2
GEO_GROQ_INTER_REQUEST_DELAY_S=0.2
GEO_DDG_REQUEST_DELAY_S=0.8
GEO_HTTP_TIMEOUT_S=30
GEO_CRAWL_MAX_CONCURRENT=5
GEO_CRAWL_TIMEOUT_S=25
GEO_CRAWL_MAX_BYTES=2000000
GEO_ZONE_METIER_DELAY_MIN_S=2
GEO_ZONE_METIER_DELAY_MAX_S=5
